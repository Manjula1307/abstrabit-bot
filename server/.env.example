# Postgres connection string from Neon (Dashboard > Connection Details)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# From GitHub OAuth App settings (github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must match your Render backend URL exactly, e.g. https://your-app.onrender.com/auth/github/callback
GITHUB_CALLBACK_URL=

# Slack Incoming Webhook URL (api.slack.com/apps -> your app -> Incoming Webhooks)
SLACK_WEBHOOK_URL=

# Any long random string, used to sign the login session cookie
JWT_SECRET=

# Optional: Groq API key (console.groq.com, free tier, no card) for the AI
# summarization/triage stretch goal. If left blank, the app still works —
# it just skips the AI summary/priority fields.
GROQ_API_KEY=

# Your deployed frontend URL, e.g. https://your-app.vercel.app (used for CORS + post-login redirect)
CLIENT_URL=http://localhost:5173

# Your deployed backend URL, e.g. https://your-app.onrender.com (used to register the webhook URL with GitHub)
SERVER_URL=http://localhost:4000

PORT=4000
